{
  "name": "talentforge-poc",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "worker",
    "smart-contracts"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:worker": "npm --workspace worker run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:worker\"",
    "build:backend": "npm --workspace backend run build",
    "build:worker": "npm --workspace worker run build",
    "build:frontend": "npm --workspace frontend run build",
    "build": "npm run build:backend && npm run build:worker && npm run build:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "msw": {
    "workerDirectory": [
      "frontend\\public"
    ]
  }
}