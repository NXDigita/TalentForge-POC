# TalentForge — copy to .env and change every value
# .env must be in .gitignore

POSTGRES_USER=talentforge
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=talentforge

REDIS_PASSWORD=change-me-strong-password

MINIO_ROOT_USER=talentforge-admin
MINIO_ROOT_PASSWORD=change-me-strong-password

